htmlcov/
.coverage

# Python related (if any Python tools used in dev workflow)
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# Build artifacts
dist/
build/
*.so
*.dylib
*.dll
*.exe
*.out

